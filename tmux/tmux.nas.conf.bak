source-file ~/.config/tmux/tmux.conf

# NAS-specific layout: single bottom status bar, no top pane border status line.
set -g status on
set -g status-position bottom
set -g status-right ""
set -g pane-border-status off
setw -g automatic-rename off

# Reload NAS config (base + NAS overrides).
bind r source-file ~/.config/tmux/tmux.nas.conf \; display "Config reloaded!"
